# ---------------------------------------------------------------------------
# Configuración del backend — copia este archivo como `.env` y ajusta valores.
# El archivo `.env` NO se versiona (ver .gitignore).
# ---------------------------------------------------------------------------

# Seguridad
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-larga
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL
DB_NAME=proyecto_terminal_cyad
DB_USER=postgres
DB_PASSWORD=tu_password_de_postgres
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS (origen del frontend Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
